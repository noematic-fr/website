---
import { content } from '../content';

const { services } = content;
---

<section id="services" class="noe-section noe-services">
  <div class="noe-container">
    <header class="noe-section-header">
      <h2>{services.title}</h2>
      <p class="noe-section-lead">{services.subtitle}</p>
    </header>
    <div class="noe-card-grid noe-card-grid--services">
      {services.items.map((item) => (
        <article class="noe-card noe-card--service">
          <div class="noe-card-icon" aria-hidden="true">{item.icon}</div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <ul class="noe-tags">
            {item.tags.map((tag) => <li>{tag}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>